{
  "$defs": {
    "AgenticParams": {
      "additionalProperties": false,
      "properties": {
        "hash_name": {
          "default": "sha256",
          "title": "Hash Name",
          "type": "string"
        },
        "shared_dir": {
          "anyOf": [
            {
              "format": "path",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Shared Dir"
        },
        "shard_width": {
          "default": 2,
          "exclusiveMinimum": 0,
          "title": "Shard Width",
          "type": "integer"
        },
        "persist_seen": {
          "default": false,
          "title": "Persist Seen",
          "type": "boolean"
        },
        "poll_interval": {
          "default": 2.0,
          "exclusiveMinimum": 0.0,
          "title": "Poll Interval",
          "type": "number"
        },
        "max_buffer": {
          "default": 7,
          "exclusiveMinimum": 0,
          "title": "Max Buffer",
          "type": "integer"
        },
        "max_retained": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Retained"
        },
        "auto_publish": {
          "default": true,
          "title": "Auto Publish",
          "type": "boolean"
        },
        "fetch_every": {
          "default": 7,
          "exclusiveMinimum": 0,
          "title": "Fetch Every",
          "type": "integer"
        },
        "strategy": {
          "default": "balanced",
          "title": "Strategy",
          "type": "string"
        }
      },
      "title": "AgenticParams",
      "type": "object"
    },
    "ConvergenceParams": {
      "additionalProperties": false,
      "properties": {
        "stall_threshold": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Stall Threshold"
        },
        "objective_threshold": {
          "default": 0.0001,
          "minimum": 0.0,
          "title": "Objective Threshold",
          "type": "number"
        },
        "alpha_discovery": {
          "default": 0.05,
          "minimum": 0.0,
          "title": "Alpha Discovery",
          "type": "number"
        },
        "alpha_progress": {
          "default": 0.05,
          "minimum": 0.0,
          "title": "Alpha Progress",
          "type": "number"
        },
        "alpha_acceptance": {
          "default": 0.1,
          "minimum": 0.0,
          "title": "Alpha Acceptance",
          "type": "number"
        },
        "max_cache_size": {
          "default": 1000000,
          "exclusiveMinimum": 0,
          "title": "Max Cache Size",
          "type": "integer"
        },
        "track_features": {
          "default": false,
          "title": "Track Features",
          "type": "boolean"
        }
      },
      "title": "ConvergenceParams",
      "type": "object"
    },
    "EnsembleBase": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/EnsembleKind",
          "default": "none"
        },
        "walkers": {
          "default": 1,
          "exclusiveMinimum": 0,
          "title": "Walkers",
          "type": "integer"
        },
        "sweeps": {
          "default": 1000,
          "exclusiveMinimum": 0,
          "title": "Sweeps",
          "type": "integer"
        },
        "burn_in": {
          "default": 0,
          "minimum": 0,
          "title": "Burn In",
          "type": "integer"
        },
        "thin": {
          "default": 1,
          "exclusiveMinimum": 0,
          "title": "Thin",
          "type": "integer"
        },
        "store_trajectory": {
          "default": true,
          "title": "Store Trajectory",
          "type": "boolean"
        }
      },
      "title": "EnsembleBase",
      "type": "object"
    },
    "EnsembleKind": {
      "enum": [
        "none",
        "gcmc",
        "replica_exchange",
        "gibbs",
        "nvt",
        "identity",
        "nested_sampling",
        "hard_constraint"
      ],
      "title": "EnsembleKind",
      "type": "string"
    },
    "EnsembleParams": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/EnsembleKind",
          "default": "none"
        },
        "base": {
          "$ref": "#/$defs/EnsembleBase"
        },
        "gcmc": {
          "anyOf": [
            {
              "$ref": "#/$defs/GCMCParams"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "replica_exchange": {
          "anyOf": [
            {
              "$ref": "#/$defs/ReplicaExchangeParams"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "gibbs": {
          "anyOf": [
            {
              "$ref": "#/$defs/GibbsParams"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "nvt": {
          "anyOf": [
            {
              "$ref": "#/$defs/NVTParams"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "nested_sampling": {
          "anyOf": [
            {
              "$ref": "#/$defs/NestedSamplingParams"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "hard_constraint": {
          "anyOf": [
            {
              "$ref": "#/$defs/HardConstraintParams"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "title": "EnsembleParams",
      "type": "object"
    },
    "EvaluatorParams": {
      "additionalProperties": false,
      "properties": {
        "features_funcs": {
          "default": null,
          "title": "Features Funcs"
        },
        "objectives_funcs": {
          "default": null,
          "title": "Objectives Funcs"
        },
        "debug": {
          "default": false,
          "title": "Debug",
          "type": "boolean"
        }
      },
      "title": "EvaluatorParams",
      "type": "object"
    },
    "GCMCParams": {
      "additionalProperties": false,
      "properties": {
        "temperature": {
          "exclusiveMinimum": 0.0,
          "title": "Temperature",
          "type": "number"
        },
        "chemical_potential": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Chemical Potential",
          "type": "object"
        },
        "move_weights": {
          "additionalProperties": {
            "exclusiveMinimum": 0.0,
            "type": "number"
          },
          "title": "Move Weights",
          "type": "object"
        },
        "max_displacement": {
          "default": 0.1,
          "exclusiveMinimum": 0.0,
          "title": "Max Displacement",
          "type": "number"
        },
        "insertion_region": {
          "default": "box",
          "enum": [
            "box",
            "slab",
            "interlayer"
          ],
          "title": "Insertion Region",
          "type": "string"
        },
        "local_relax_after_accept": {
          "default": false,
          "title": "Local Relax After Accept",
          "type": "boolean"
        }
      },
      "required": [
        "temperature"
      ],
      "title": "GCMCParams",
      "type": "object"
    },
    "GenerativeParams": {
      "additionalProperties": false,
      "description": "Generative proposal model (Bayesian Optimization by default).\n\nEnabled iff `size > 0`.",
      "properties": {
        "size": {
          "default": 0,
          "minimum": 0,
          "title": "Size",
          "type": "integer"
        },
        "start_gen": {
          "default": 0,
          "minimum": 0,
          "title": "Start Gen",
          "type": "integer"
        },
        "every": {
          "default": 1,
          "exclusiveMinimum": 0,
          "title": "Every",
          "type": "integer"
        },
        "fit_frequency": {
          "default": 1,
          "exclusiveMinimum": 0,
          "title": "Fit Frequency",
          "type": "integer"
        },
        "candidate_multiplier": {
          "default": 10,
          "exclusiveMinimum": 0,
          "title": "Candidate Multiplier",
          "type": "integer"
        },
        "training_subsample": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": 200,
          "title": "Training Subsample"
        },
        "subsample_strategy": {
          "default": "random",
          "enum": [
            "random",
            "diverse"
          ],
          "title": "Subsample Strategy",
          "type": "string"
        },
        "warm_start": {
          "default": true,
          "title": "Warm Start",
          "type": "boolean"
        },
        "use_ard": {
          "default": true,
          "title": "Use Ard",
          "type": "boolean"
        },
        "n_restarts_optimizer": {
          "default": 5,
          "minimum": 0,
          "title": "N Restarts Optimizer",
          "type": "integer"
        },
        "save_model": {
          "default": false,
          "title": "Save Model",
          "type": "boolean"
        },
        "save_path": {
          "anyOf": [
            {
              "format": "path",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Save Path"
        },
        "discrete_design": {
          "default": true,
          "title": "Discrete Design",
          "type": "boolean"
        },
        "tolerance": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "items": {
                "type": "number"
              },
              "type": "array"
            }
          ],
          "default": 0.1,
          "title": "Tolerance"
        },
        "max_variation_iterations": {
          "default": 20,
          "exclusiveMinimum": 0,
          "title": "Max Variation Iterations",
          "type": "integer"
        },
        "max_mutations": {
          "default": 200,
          "exclusiveMinimum": 0,
          "title": "Max Mutations",
          "type": "integer"
        },
        "bo_kwargs": {
          "anyOf": [
            {
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Bo Kwargs"
        },
        "custom": {
          "anyOf": [
            {
              "description": "Callable function or shorthand",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Custom"
        }
      },
      "title": "GenerativeParams",
      "type": "object"
    },
    "GibbsParams": {
      "additionalProperties": false,
      "properties": {
        "boxes": {
          "default": 2,
          "exclusiveMinimum": 0,
          "title": "Boxes",
          "type": "integer"
        },
        "transfer_weight": {
          "default": 0.9,
          "exclusiveMinimum": 0.0,
          "title": "Transfer Weight",
          "type": "number"
        },
        "volume_weight": {
          "default": 0.1,
          "exclusiveMinimum": 0.0,
          "title": "Volume Weight",
          "type": "number"
        },
        "allow_volume_exchange": {
          "default": true,
          "title": "Allow Volume Exchange",
          "type": "boolean"
        },
        "total_volume": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Volume"
        },
        "total_particles": {
          "anyOf": [
            {
              "additionalProperties": {
                "type": "integer"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Total Particles"
        },
        "internal_weight": {
          "default": 1.0,
          "exclusiveMinimum": 0.0,
          "title": "Internal Weight",
          "type": "number"
        }
      },
      "title": "GibbsParams",
      "type": "object"
    },
    "HardConstraintParams": {
      "additionalProperties": false,
      "properties": {},
      "title": "HardConstraintParams",
      "type": "object"
    },
    "HiSEParams": {
      "additionalProperties": false,
      "description": "Hierarchical Supercell Escalation (HiSE) coarse-to-fine settings.",
      "properties": {
        "supercells": {
          "description": "Sequence of supercells, e.g. [[1,1,1],[2,1,1],[2,2,1]]",
          "items": {
            "maxItems": 3,
            "minItems": 3,
            "prefixItems": [
              {
                "type": "integer"
              },
              {
                "type": "integer"
              },
              {
                "type": "integer"
              }
            ],
            "type": "array"
          },
          "title": "Supercells",
          "type": "array"
        },
        "input_from": {
          "default": "final_dataset",
          "description": "Where to read previous stage input from: final_dataset (root config.xyz) or latest_generation (scan generation/*/config.xyz).",
          "enum": [
            "final_dataset",
            "latest_generation"
          ],
          "title": "Input From",
          "type": "string"
        },
        "stage_dir_pattern": {
          "default": "supercell_{a}_{b}_{c}",
          "description": "Subdirectory name per stage under GAConfig.output_path.",
          "title": "Stage Dir Pattern",
          "type": "string"
        },
        "restart": {
          "default": true,
          "description": "Skip stages already complete; resume partial if possible.",
          "title": "Restart",
          "type": "boolean"
        },
        "overrides": {
          "anyOf": [
            {
              "additionalProperties": {
                "items": {},
                "type": "array"
              },
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Stage-specific overrides by key path (dot-notation) \u2192 list of values per stage.",
          "title": "Overrides"
        },
        "carry": {
          "default": "all",
          "enum": [
            "pareto",
            "elites",
            "all"
          ],
          "title": "Carry",
          "type": "string"
        },
        "reseed_fraction": {
          "default": 1.0,
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Reseed Fraction",
          "type": "number"
        },
        "lift_method": {
          "const": "tile",
          "default": "tile",
          "title": "Lift Method",
          "type": "string"
        }
      },
      "required": [
        "supercells"
      ],
      "title": "HiSEParams",
      "type": "object"
    },
    "NVTParams": {
      "additionalProperties": false,
      "properties": {
        "temperature": {
          "exclusiveMinimum": 0.0,
          "title": "Temperature",
          "type": "number"
        }
      },
      "required": [
        "temperature"
      ],
      "title": "NVTParams",
      "type": "object"
    },
    "NestedSamplingParams": {
      "additionalProperties": false,
      "description": "NestedSamplingKernel assumes that candidates provided\nby the upstream generator approximate independent\nsamples from the constrained prior:\n    \u03c0(\u03b8 | \u03a6 < \u03a6*)\nViolation of this assumption biases NS weights.",
      "properties": {
        "chemical_potential": {
          "additionalProperties": {
            "type": "number"
          },
          "title": "Chemical Potential",
          "type": "object"
        },
        "stochastic_shrinkage": {
          "default": false,
          "title": "Stochastic Shrinkage",
          "type": "boolean"
        },
        "strict_ns": {
          "default": false,
          "title": "Strict Ns",
          "type": "boolean"
        },
        "T": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "T"
        },
        "beta": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Beta"
        },
        "tolerance": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tolerance"
        },
        "track_diagnostics": {
          "default": true,
          "title": "Track Diagnostics",
          "type": "boolean"
        },
        "n_live": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "N Live"
        },
        "step_interval": {
          "default": 1,
          "exclusiveMinimum": 0,
          "title": "Step Interval",
          "type": "integer"
        }
      },
      "title": "NestedSamplingParams",
      "type": "object"
    },
    "PopulationParams": {
      "additionalProperties": false,
      "properties": {
        "dataset_path": {
          "anyOf": [
            {
              "format": "path",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dataset Path"
        },
        "template_path": {
          "anyOf": [
            {
              "format": "path",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Template Path"
        },
        "db_path": {
          "anyOf": [
            {
              "format": "path",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Db Path"
        },
        "db_ro_path": {
          "anyOf": [
            {
              "format": "path",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Db Ro Path"
        },
        "filter_duplicates": {
          "default": true,
          "title": "Filter Duplicates",
          "type": "boolean"
        },
        "size_limit": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Size Limit"
        },
        "constraints": {
          "anyOf": [
            {
              "items": {
                "anyOf": [
                  {
                    "description": "Callable function or shorthand",
                    "type": "string"
                  },
                  {
                    "type": "object"
                  }
                ]
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Constraints"
        },
        "ef_bounds": {
          "anyOf": [
            {
              "maxItems": 2,
              "minItems": 2,
              "prefixItems": [
                {
                  "type": "number"
                },
                {
                  "type": "number"
                }
              ],
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Ef Bounds"
        },
        "collision_factor": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": 0.8,
          "title": "Collision Factor"
        },
        "blacklist": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Blacklist"
        },
        "fetch_limit": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fetch Limit"
        },
        "skip_hashing": {
          "default": false,
          "title": "Skip Hashing",
          "type": "boolean"
        },
        "skip_lineage": {
          "default": true,
          "title": "Skip Lineage",
          "type": "boolean"
        },
        "seed": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Seed"
        }
      },
      "title": "PopulationParams",
      "type": "object"
    },
