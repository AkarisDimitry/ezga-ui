          "title": "Method",
          "type": "string"
        },
        "r_max": {
          "default": 10.0,
          "exclusiveMinimum": 0.0,
          "title": "R Max",
          "type": "number"
        },
        "bin_width": {
          "default": 0.02,
          "exclusiveMinimum": 0.0,
          "title": "Bin Width",
          "type": "number"
        },
        "density_grid": {
          "default": 0.0001,
          "exclusiveMinimum": 0.0,
          "title": "Density Grid",
          "type": "number"
        },
        "e_grid": {
          "default": 0.01,
          "exclusiveMinimum": 0.0,
          "title": "E Grid",
          "type": "number"
        },
        "v_grid": {
          "default": 0.01,
          "exclusiveMinimum": 0.0,
          "title": "V Grid",
